{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "keepUpdatedLabel": "renovate:keep-updated",
  "lockFileMaintenance": {
    "automerge": false,
    "enabled": true,
    "extends": [
      "schedule:daily"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+) versioning=(?<versioning>[^\\s]+)\\nARG \\w+=(?<currentValue>.+)"
      ],
      "extractVersionTemplate": "^(v|go)?(?<version>[\\d][\\d.]+.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["\\.js$"],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+) versioning=(?<versioning>[^\\s]+)\\nconst \\w+\\s*=\\s*\"(?<currentValue>[^\"]+)\";"
      ],
      "extractVersionTemplate": "^(v|go)?(?<version>[\\d][\\d.]+.*)$"
    }
  ],
  "packageRules": [
    {
      "automerge": false,
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest"
      ]
    },
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["node/node"],
      "matchFileNames": ["images/node-rbenv/node-[0-9]*/**", "test/**"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchDatasources": ["github-releases"],
      "matchDepNames": ["ruby/ruby"],
      "matchFileNames": ["images/**/ruby-[0-9]*/**", "test/**"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "rebaseLabel": "renovate:rebase",
  "stopUpdatingLabel": "renovate:disabled",
  "timezone": "Europe/Vienna"
}
